<table>
    <tr><td><b>Tarih:</b></td><td>{kontrolTarihi}</td><td><b>Sefer / Sevkiyat No:</b></td><td>{seferNo}</td></tr>
    <tr><td><b>Araç Plakası:</b></td><td>{aracPlakasi}</td><td><b>Dorse / Treyler No:</b></td><td>{dorseNo}</td></tr>
    <tr><td><b>Sürücü Adı Soyadı:</b></td><td>{surucuAdi}</td><td><b>Konteyner No:</b></td><td>{konteynerNo}</td></tr>
    <tr><td><b>Yük Cinsi / Tanımı:</b></td><td>{yukCinsi}</td><td><b>Toplam Ağırlık (kg):</b></td><td>{toplamAgirlik}</td></tr>
    <tr><td><b>Yükleme Yeri:</b></td><td>{yuklemeYeri}</td><td><b>Boşaltma Yeri:</b></td><td>{bosaltmaYeri}</td></tr>
</table>

<table>
    <tr><th>KONTROL MADDESİ</th><th>Evet</th><th>Hayır</th><th>U.D.</th><th>Açıklama</th></tr>
    <tr><td colspan="5" style="border:none; padding:2px;">{#lashingKontrolMaddeleri}</td></tr>
    <tr><td>{kontrolMaddesi}</td><td>{evet}</td><td>{hayir}</td><td>{ud}</td><td>{aciklama}</td></tr>
